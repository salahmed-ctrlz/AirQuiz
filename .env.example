# Frontend Environment Variables
# Socket.IO / API backend URL — auto-detected on LAN, override for production
VITE_SOCKET_URL=http://localhost:8000
VITE_API_URL=http://localhost:8000

# Admin dashboard password
VITE_ADMIN_PASSWORD=airquiz2024

# Set to "true" to enable offline demo mode (no backend needed)
VITE_DEMO_MODE=false

# Backend Environment Variables (read by backend/config.py)
# DATABASE_URL=sqlite:///./airquiz.db
# BACKEND_HOST=0.0.0.0
# BACKEND_PORT=8000
# CORS_ORIGINS=*
# EXAMS_DIR=../exams
# LOG_LEVEL=info
